{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PORULLE_API_URL",
    "NEXT_PUBLIC_PORULLE_API_URL",
    "PORULLE_ADMIN_API_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SITE_NAME",
    "NEXT_PUBLIC_BASE_URL",
    "NEXT_PUBLIC_ENABLE_AUTH",
    "NEXT_PUBLIC_ENABLE_AGENT",
    "VERCEL_PROJECT_PRODUCTION_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "check-types": {
      "dependsOn": ["^build"]
    }
  }
}
