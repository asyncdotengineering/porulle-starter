# ── porulle backend ───────────────────────────────────────────────────────
# Origin of the porulle backend this admin talks to (server-to-server).
PORULLE_API_URL="http://localhost:4000"

# Admin-scoped API key that authorizes catalog/pricing/order writes. Mint it
# (and the login user below) with: pnpm --filter backend key:admin
PORULLE_ADMIN_API_KEY="pk_admin_..."

# ── Admin login gate ──────────────────────────────────────────────────────
# Comma-separated allowlist of porulle Better Auth emails permitted to sign in.
ADMIN_EMAILS="admin@porulle.local"

# Secret used to HMAC-sign the admin session cookie. Generate one with:
# openssl rand -base64 32
ADMIN_SESSION_SECRET="change-me"
