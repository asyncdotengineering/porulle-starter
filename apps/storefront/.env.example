# ── porulle backend ───────────────────────────────────────────────────────
# Base URL of your porulle commerce server. The storefront talks to it
# server-side (server components + server actions); it is never exposed to the
# browser. Catalog reads are anonymous; cart/checkout go through server actions.
PORULLE_API_URL="http://localhost:4000"
# REQUIRED: the storefront's server API key (prefix pk_porulle_), minted by
# `pnpm --filter backend key:create`. Catalog reads are anonymous, but every
# cart and checkout write is authenticated — without this key those writes 403.
# This is NOT the admin key: the admin key deliberately lacks cart permissions.
PORULLE_STOREFRONT_API_KEY="pk_porulle_..."

# ── Stripe (client) ───────────────────────────────────────────────────────
# Publishable key for the Stripe Payment Element. The SECRET key lives in the
# backend (apps/backend/.env), not here. When this is unset, checkout uses the
# backend's dev mock adapter and skips the card form (useful for a first run).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Storefront ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME="Porulle Starter"
# Canonical site origin (used for SEO/sitemap absolute URLs).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ── AI shopping assistant (optional) ──────────────────────────────────────
# Enable the AI shopping agent (floating chat + product/cart tools over porulle).
NEXT_PUBLIC_ENABLE_AGENT="1"
# The agent calls an LLM through the Vercel AI Gateway. Set a gateway key locally
# (on Vercel it's injected automatically). https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=""
# Optional: override the agent model (Vercel AI Gateway id).
# AGENT_MODEL="anthropic/claude-sonnet-4.5"
