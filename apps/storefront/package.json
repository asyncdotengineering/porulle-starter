{
  "name": "storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "codegen": "openapi-typescript ${PORULLE_API_URL:-http://localhost:4000}/api/doc -o lib/commerce/generated/api-types.ts",
    "build": "next build",
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "format": "oxfmt",
    "lint": "oxlint . && oxfmt --check",
    "start": "next start",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "4.0.5",
    "@json-render/core": "0.19.0",
    "@json-render/react": "0.19.0",
    "@porulle/sdk": "^0.10.4",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.6.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tailwindcss/typography": "0.5.20",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ai": "7.0.4",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.21.0",
    "nanoid": "5.1.16",
    "next": "16.3.0-canary.70",
    "next-intl": "4.13.0",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "use-stick-to-bottom": "1.1.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "postcss": "8.5.15",
    "typescript": "6.0.3"
  }
}
