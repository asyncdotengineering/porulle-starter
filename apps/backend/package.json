{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Porulle headless commerce backend for porulle-starter (Postgres + Stripe).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "key:create": "tsx src/create-api-key.ts",
    "key:admin": "tsx src/create-admin.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "setup": "pnpm db:push && pnpm seed",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@porulle/adapter-local-storage": "^0.10.4",
    "@porulle/adapter-pglite": "^0.10.4",
    "@porulle/adapter-postgres": "^0.10.4",
    "@porulle/adapter-stripe": "^0.10.4",
    "@porulle/core": "^0.10.4",
    "@porulle/plugin-giftcards": "^0.10.4",
    "hono": "^4.9.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.6",
    "typescript": "5.9.2"
  }
}
