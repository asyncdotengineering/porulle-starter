# ── Database ──────────────────────────────────────────────────────────────
# Any managed or local Postgres. The db:push + seed scripts target this.
DATABASE_URL="postgres://localhost:5432/porulle_starter"

# ── Public URLs ───────────────────────────────────────────────────────────
# Canonical origin of THIS backend (used for media URLs + auth cookies).
PUBLIC_URL="http://localhost:4000"
# The storefront origin (added to trustedOrigins for browser auth/CSRF).
STOREFRONT_URL="http://localhost:3000"
# The admin panel origin (added to trustedOrigins for its Better Auth login).
ADMIN_URL="http://localhost:3001"
PORT="4000"
STORE_NAME="Porulle Starter"

# ── Stripe (payment gateway) ──────────────────────────────────────────────
# Without STRIPE_SECRET_KEY the backend boots with a dev mock payment adapter.
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen --forward-to localhost:4000/api/payments/webhook`
# or the Stripe Dashboard webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
